{
  "name": "secure-vault",
  "version": "1.0.0",
  "description": "A secure password management application built with Electron and React",
  "type": "module",
  "main": "public/electron.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --ui --coverage",
    "test:coverage:check": "node scripts/coverage-check.js",
    "electron": "electron .",
    "electron-dev": "npm run stop; concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-pack": "npm run build && electron-builder",
    "preelectron-pack": "npm run build",
    "prepare": "husky",
    "stop": "ps aux | grep -e 'Electron.app' | awk '{ print $2}' | xargs kill -9"
  },
  "dependencies": {
    "@electron-webauthn/native": "github:iamEvanYT/electron-webauthn-native",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.1",
    "@mui/material": "^5.14.1",
    "@simplewebauthn/browser": "^13.1.2",
    "bcrypt": "^5.1.0",
    "crypto-js": "^4.1.1",
    "electron-is-dev": "^2.0.0",
    "electron-webauthn": "^0.0.1",
    "fs-extra": "^11.1.1",
    "node-forge": "^1.3.1",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.14.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^8.2.0",
    "electron": "^37.2.6",
    "electron-builder": "^24.4.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-react-devtools": "^0.5.3",
    "eslint": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "react-devtools": "^6.1.5",
    "vite": "^7.1.1",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^3.2.4",
    "wait-on": "^7.0.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.securevault.app",
    "productName": "Secure Password Manager",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/**/*",
      "public/electron.cjs",
      "public/preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "entitlements": "public/entitlements.plist",
      "entitlementsInherit": "public/entitlements.plist",
      "hardenedRuntime": true
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
