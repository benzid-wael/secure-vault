{
  "name": "secure-password-manager",
  "version": "1.0.0",
  "description": "A secure password management application built with Electron and React",
  "type": "module",
  "main": "public/electron.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-pack": "npm run build && electron-builder",
    "preelectron-pack": "npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.1",
    "@mui/material": "^5.14.1",
    "bcrypt": "^5.1.0",
    "crypto-js": "^4.1.1",
    "electron": "^37.2.6",
    "electron-is-dev": "^2.0.0",
    "fs-extra": "^11.1.1",
    "node-forge": "^1.3.1",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.14.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.4.0",
    "jsdom": "^25.0.1",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.securepasswordmanager.app",
    "productName": "Secure Password Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/electron.cjs",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
